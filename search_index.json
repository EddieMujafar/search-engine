g": 1, "def": 1, "keyword": 3, "support": 6, "default": 1, "arguments": 3, "vari": 1, "args": 1, "kwargs": 1, "classes": 1, "use": 1, "class": 1, "define": 1, "inherit": 1, "encapsulate": 1, "polymorphism": 1, "popular": 1, "libraries": 1, "numpy": 1, "numeric": 1, "comput": 1, "pandas": 1, "analysis": 1, "matplotlib": 1, "visualize": 1, "tensorflow": 1, "machine": 1, "learn": 1, "flask": 1, "web": 1, "develop": 1}, "2": {"web": 9, "develop": 5, "basics": 1, "involves": 1, "creat": 1, "websites": 1, "applications": 1, "internet": 1, "frontend": 2, "technologies": 2, "html": 1, "structure": 1, "cont": 1, "css": 1, "styl": 1, "layout": 1, "javascript": 3, "interactivity": 1, "behavior": 1, "react": 1, "compon": 1, "based": 1, "ui": 2, "library": 1, "vue": 1, "progress": 1, "framework": 7, "angular": 1, "full": 1, "featured": 1, "applicate": 2, "backend": 2, "node": 1, "js": 1, "runtime": 1, "express": 1, "django": 1, "python": 2, "flask": 1, "lightweight": 1, "ruby": 2, "rails": 1, "spr": 1, "java": 1, "database": 4, "systems": 1, "mysql": 1, "relate": 2, "postgresql": 1, "advanced": 1, "mongodb": 1, "nosql": 1, "docu": 1, "redis": 1, "memory": 1, "data": 1, "store": 1, "process": 1, "plann": 1, "requirements": 1, "gather": 1, "ux": 1, "design": 2, "test": 1, "debugg": 1, "deploy": 1, "mainten": 1, "best": 2, "practices": 2, "use": 1, "version": 1, "control": 1, "git": 1, "write": 1, "clean": 1, "documented": 1, "code": 1, "impl": 1, "respons": 1, "optimize": 1, "perform": 1, "ensure": 1, "security": 1}}, "doc_lengths": {"0": 86, "1": 94, "2": 117}, "documents": {"0": {"doc_id": 0, "path": "sample_docs\\machine_learning.txt", "title": "machine_learning.txt", "content": "Machine Learning Fundamentals\n\nMachine learning is a subset of artificial intelligence that focuses on creating systems that can learn from and make decisions based on data.\n\nTypes of Machine Learning:\n1. Supervised Learning - Learning with labeled data\n2. Unsupervised Learning - Finding patterns in unlabeled data\n3. Reinforcement Learning - Learning through trial and error\n\nKey Concepts:\n- Training Data: The dataset used to train models\n- Features: Input variables used for prediction\n- Labels: Output variables we want to predict\n- Model: The mathematical representation learned from data\n\nCommon Algorithms:\n- Linear Regression\n- Decision Trees\n- Random Forests\n- Neural Networks\n- Support Vector Machines\n\nMachine learning applications include image recognition, natural language processing, recommendation systems, and predictive analytics.", "word_count": 122, "indexed_at": 1777453846.5530949}, "1": {"doc_id": 1, "path": "sample_docs\\python.txt", "title": "python.txt", "content": "Python Programming Guide\n\nPython is a high-level, interpreted programming language known for its simplicity and readability.\n\nKey Features:\n- Dynamic typing\n- Automatic memory management\n- Extensive standard library\n- Cross-platform compatibility\n\nData Types:\n- Numbers (int, float, complex)\n- Strings\n- Lists\n- Tuples\n- Dictionaries\n- Sets\n\nControl Structures:\n- if/elif/else statements\n- for loops\n- while loops\n- try/except for error handling\n\nFunctions:\n- Defined using def keyword\n- Support default arguments\n- Support keyword arguments\n- Support variable arguments (*args, **kwargs)\n\nClasses:\n- Use class keyword to define\n- Support inheritance\n- Support encapsulation\n- Support polymorphism\n\nPopular Python Libraries:\n- NumPy: Numerical computing\n- Pandas: Data analysis\n- Matplotlib: Data visualization\n- TensorFlow: Machine learning\n- Flask: Web development", "word_count": 124, "indexed_at": 1777453846.5539513}, "2": {"doc_id": 2, "path": "sample_docs\\web_development.txt", "title": "web_development.txt", "content": "Web Development Basics\n\nWeb development involves creating websites and web applications for the internet.\n\nFrontend Technologies:\n- HTML: Structure and content\n- CSS: Styling and layout\n- JavaScript: Interactivity and behavior\n- React: Component-based UI library\n- Vue: Progressive JavaScript framework\n- Angular: Full-featured web application framework\n\nBackend Technologies:\n- Node.js: JavaScript runtime\n- Express: Web application framework\n- Django: Python web framework\n- Flask: Lightweight Python framework\n- Ruby on Rails: Ruby web framework\n- Spring: Java web framework\n\nDatabase Systems:\n- MySQL: Relational database\n- PostgreSQL: Advanced relational database\n- MongoDB: NoSQL document database\n- Redis: In-memory data store\n\nWeb Development Process:\n1. Planning and requirements gathering\n2. UI/UX design\n3. Frontend development\n4. Backend development\n5. Testing and debugging\n6. Deployment and maintenance\n\nBest Practices:\n- Use version control (Git)\n- Write clean, documented code\n- Implement responsive design\n- Optimize for performance\n- Ensure security best practices", "word_count": 151, "indexed_at": 1777453846.5553343}}, "doc_count": 3}